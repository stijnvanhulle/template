{
  "name": "@stijnvanhulle/eslint-config",
  "version": "1.1.8",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./legacy": {
      "import": "./dist/legacy.mjs",
      "require": "./dist/legacy.cjs",
      "default": "./dist/legacy.cjs"
    },
    "./flat": {
      "import": "./dist/flat.mjs",
      "require": "./dist/flat.cjs",
      "default": "./dist/flat.cjs"
    },
    "./package.json": "./package.json",
    "./*": "./*"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "src",
    "dist",
    "!/**/**.test.**",
    "!/**/__tests__/**"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "npx rimraf ./dist",
    "lint": "ESLINT_USE_FLAT_CONFIG=true eslint --format pretty .",
    "lint-fix": "bun run lint --quiet --fix",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../../.github/canary.sh && node ../../../scripts/build.js canary && pnpm publish --no-git-check",
    "start": "tsdown --watch",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@eslint/js": "^8.55.0",
    "@types/eslint": "~8.44.9",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "~6.7.5",
    "eslint-config-prettier": "~9.0.0",
    "eslint-config-turbo": "~1.10.16",
    "eslint-formatter-pretty": "^5.0.0",
    "eslint-plugin-eslint-plugin": "^5.2.1",
    "eslint-plugin-import": "~2.28.1",
    "eslint-plugin-react": "~7.33.2",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-turbo": "~1.10.16",
    "eslint-plugin-unused-imports": "~3.0.0",
    "eslint-plugin-vitest": "~0.3.17",
    "eslint-plugin-vitest-globals": "~1.4.0",
    "globals": "^13.24.0"
  },
  "devDependencies": {
    "@stijnvanhulle/ts-config": "workspace:*",
    "@stijnvanhulle/tsdown-config": "workspace:*",
    "eslint": "^8.55.0",
    "tsdown": "^0.18.4",
    "typescript": "~5.2.2"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
