{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../configs/bundler.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": ".tsbuild",
    "rootDir": "src",
    "types": ["bun-types", "../../reset.d.ts"]
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts", "src/**/*.bench.ts"]
}
