{
  "name": "@stijnvanhulle/template-core",
  "version": "0.0.0",
  "description": "Core package",
  "license": "MIT",
  "author": "Stijn Van Hulle <stijn@stijnvanhulle.be>",
  "repository": {
    "type": "git",
    "url": "https://github.com/stijnvanhulle/template.git",
    "directory": "packages/core"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf ./dist",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../.github/canary.sh && pnpm publish --no-git-check",
    "start": "tsdown --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11.0.0"
  }
}
