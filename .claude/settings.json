{
  "permissions": {
    "allow": [
      "Bash(pnpm typecheck *)",
      "Bash(pnpm --filter * typecheck *)",
      "Bash(pnpm --filter * exec tsc *)",
      "Bash(pnpm test --run *)",
      "Bash(pnpm test *)",
      "Bash(pnpm test:bench *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm lint:fix *)",
      "Bash(pnpm lint:spell *)",
      "Bash(pnpm format *)",
      "Bash(pnpm generate *)",
      "Bash(pnpm clean *)",
      "Bash(pnpm graph *)",
      "Bash(pnpm install*)",
      "Bash(pnpm build*)",
      "Bash(npm run lint *)",
      "Bash(npm run format *)",
      "Bash(npm run typecheck *)",
      "Bash(git status*)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format.sh"
          }
        ]
      }
    ]
  }
}
