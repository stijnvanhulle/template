  "extends": "../../configs/bundler.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": ".tsbuild",
    "types": ["bun-types", "../../reset.d.ts", "@playwright/test"]
